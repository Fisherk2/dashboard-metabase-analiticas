# =============================================================================
# Environment Variables — Dashboard Metabase + Colección Analítica
# =============================================================================
# Copy this file to .env and replace placeholder values before running the
# project. The Makefile loads these automatically via `include .env`.
#
#   cp .env.example .env
#   make setup
#
# NEVER commit the actual .env file — it is excluded by .gitignore.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=ecommerce
POSTGRES_PORT=5432

# --- Metabase ---
METABASE_PORT=3000
# Metabase admin credentials (for API setup script)
# MB_USER must be a valid email address (e.g., admin@example.com)
MB_USER=admin@example.com
# MB_PASSWORD must meet Metabase requirements: uppercase, lowercase, digit, 8+ chars
MB_PASSWORD=change-me-in-production
MB_DB_TYPE=postgres
MB_DB_DBNAME=${POSTGRES_DB}
MB_DB_PORT=${POSTGRES_PORT}
MB_DB_USER=${POSTGRES_USER}
MB_DB_PASS=${POSTGRES_PASSWORD}
MB_DB_HOST=postgres
# Metabase uses this key to encrypt credentials stored in the application DB.
# Generate with: openssl rand -base64 32
MB_ENCRYPTION_SECRET_KEYS=replace-with-openssl-rand-base64-32

# --- Docker Compose ---
COMPOSE_PROJECT_NAME=metabase-dashboard

# --- Data Generation ---
DATA_ROWS_SALES=100000
DATA_ROWS_PRODUCTS=5000
